<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <include
        android:id="@+id/header"
        layout="@layout/include_dashboard_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutTitles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:id="@+id/tvPhaseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NUEVO BLOQUEO"
            android:textColor="?attr/doSkinButton"
            android:fontFamily="@font/anton_regular"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona tu veneno. Tus peores vicios ya están marcados."
            android:fontFamily="@font/poppins_regular"
            android:textColor="#808080"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etBlockName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@drawable/bg_capsule_white"
                android:elevation="2dp"
                android:fontFamily="@font/poppins_bold"
                android:hint="Dale un nombre a tu bloqueo!"
                android:inputType="textCapWords"
                android:maxLength="10"
                android:paddingHorizontal="16dp"
                android:textColor="#333333"
                android:textColorHint="#A0A0A0"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnDeleteBlock"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:layout_marginStart="8dp"
                android:text="ELIMINAR"
                android:textColor="#FF3B30"
                android:fontFamily="@font/poppins_bold"
                android:textSize="12sp"
                android:background="@drawable/bg_capsule_white"
                android:elevation="2dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTitles"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/layoutTitles"
        app:layout_constraintBottom_toBottomOf="parent">

        <ProgressBar
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="?attr/doSkinButton" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analizando tus pecados de esta semana..."
            android:fontFamily="@font/poppins_bold"
            android:textColor="#808080"
            android:textSize="14sp"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnSaveBlock"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="¡GUARDAR LISTA NEGRA!"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_bold"
        android:textSize="16sp"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>