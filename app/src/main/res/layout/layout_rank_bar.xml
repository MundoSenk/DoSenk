<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <View
        android:id="@+id/trackBackground"
        android:layout_width="12dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_capsule_glass"
        app:layout_constraintTop_toTopOf="@id/llRanks"
        app:layout_constraintBottom_toBottomOf="@id/llRanks"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:id="@+id/trackFill"
        android:layout_width="12dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_skin"
        app:layout_constraintBottom_toBottomOf="@id/trackBackground"
        app:layout_constraintStart_toStartOf="@id/trackBackground"
        app:layout_constraintEnd_toEndOf="@id/trackBackground" />

    <LinearLayout
        android:id="@+id/llRanks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
