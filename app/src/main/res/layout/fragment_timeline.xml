<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F9">

    <include
        android:id="@+id/header"
        layout="@layout/include_dashboard_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutFilterGradient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/layoutHeaderClickable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Tablero de Misiones"
                        android:fontFamily="@font/anton_regular"
                        android:textColor="@color/white"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/tvCurrentDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15/12/2025"
                        android:fontFamily="@font/anton_regular"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutTabs"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:weightSum="3"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tabDay"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_capsule_white"
                        android:backgroundTint="#888888"
                        android:gravity="center"
                        android:text="Día"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/tabWeek"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_capsule_white"
                        app:backgroundTint="?attr/doSkinButton"
                        android:gravity="center"
                        android:text="Semana"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/tabMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_capsule_white"
                        android:backgroundTint="#888888"
                        android:gravity="center"
                        android:text="Mes"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSearchBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:padding="12dp">

                <TextView
                    android:id="@+id/btnFilterDate"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dashed_border"
                    android:text="15/12/2025"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                    android:drawablePadding="8dp" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content" />

                <EditText
                    android:id="@+id/etSearchMission"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dashed_border"
                    android:hint="Buscar palabra clave"
                    android:textColorHint="#888888"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="16dp"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="8dp"
                    android:inputType="text"
                    android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTimeline"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/cardFilter"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"/>

    <LinearLayout
        android:id="@+id/layoutWeeklyView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardFilter"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnPrevWeek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;-- Semana"
                android:textColor="#888888"
                android:padding="8dp"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/btnNextWeek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semana --&gt;"
                android:textColor="#888888"
                android:padding="8dp"
                android:layout_alignParentEnd="true"/>

            <TextView
                android:id="@+id/tvWeekRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando fechas..."
                android:textColor="?attr/doSkinButton"
                android:fontFamily="@font/poppins_bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWeeklyGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingBottom="100dp"/>
    </LinearLayout>

    <include
        android:id="@+id/bottomNav"
        layout="@layout/include_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>