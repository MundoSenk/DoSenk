<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <include
        android:id="@+id/header"
        layout="@layout/include_dashboard_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/cardStats"
        layout="@layout/include_dashboard_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/poppins_bold"
        android:text="¡Muy vacío todo por aquí!"
        android:textColor="#3D3D5C"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardStats" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:elevation="15dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardTimerFloating"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        app:cardElevation="25dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/white"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvEmptyState">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTimerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRÓXIMA\nMISIÓN EN:"
                android:textAlignment="center"
                android:textColor="?attr/doSkinButton"
                android:fontFamily="@font/anton_regular"
                android:textSize="18sp"/>

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                app:tint="?attr/doSkinButton"/>

            <TextView
                android:id="@+id/tvTimerCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="00:00:15"
                android:textColor="?attr/doSkinButton"
                android:fontFamily="@font/anton_regular"
                android:textSize="28sp"/>

            <TextView
                android:id="@+id/tvTimerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="¿Eres capaz de\nresistir?"
                android:textAlignment="center"
                android:textColor="#333333"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="10sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Bloqueo: DIOS"
                android:textColor="?attr/doSkinButton"
                android:fontFamily="@font/poppins_bold"
                android:textSize="10sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBottomDialogs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="20dp">

        <ImageView
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:src="@drawable/perro_tutorial"
            android:layout_marginBottom="-20dp"
            android:layout_marginEnd="-20dp"
            app:layout_constraintBottom_toTopOf="@id/cardDialogBottom"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_skin"
            android:fontFamily="@font/anton_regular"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:text="Asistente de >Do"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:elevation="6dp"
            android:translationY="12dp"
            app:layout_constraintBottom_toTopOf="@id/cardDialogBottom"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardDialogBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="0dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="32dp">

                <LinearLayout
                    android:id="@+id/layoutState1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="BUEN TRABAJO, @User! Has activado tu primera misión por 2:30 minutos...\nAsí que con eso tengo la autorización de construirte tu HOME!"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/btnAdelante"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="¿Adelante?"
                        android:textColor="?attr/doSkinButton"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutState2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Esta carta te ayudará a saber 2 cosas:\n1. En cuánto tiempo iniciará tu próxima tarea.\n2. Si una misión está activa te dirá cuánto tiempo le resta. ¡COMO AHORITA!"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/btnEntiendo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Entiendo..."
                        android:textColor="?attr/doSkinButton"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutState3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Espera, ¡activaste el bloqueo más letal!\n¡Eres todo un loco! Jajaj Suerte usando tu teléfono... nos vemos en 2:30 min."
                        android:textColor="#333333"
                        android:textSize="14sp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <TextView
                            android:id="@+id/btnNoDecidiEso"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/poppins_bold"
                            android:text="¡Espera, yo no\ndecidí eso!"
                            android:textAlignment="center"
                            android:textColor="?attr/doSkinButton"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/btnQueQuieresDecir"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/poppins_bold"
                            android:text="¿Qué quieres\ndecir?"
                            android:textAlignment="center"
                            android:textColor="?attr/doSkinButton"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>