<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2000000"> <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginHorizontal="24dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="24dp"
    app:cardElevation="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_skin"
            android:fontFamily="@font/anton_regular"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:text=">Do"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Hola, usuario ingenuo."
            android:textColor="@color/white"
            android:textSize="22sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Odio las presentaciones así que juguemos... Intenta abrir una aplicación.\n\nQuitando llamadas claro, eso es de cobardes."
            android:textAlignment="center"
            android:textColor="#B3B3B3"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/tvBossTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/anton_regular"
            android:text="00:02:30"
            android:textColor="?attr/doSkinButton"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Para que seas libre."
            android:textColor="#555555"
            android:textSize="12sp" />


        <Button
            android:id="@+id/btnGiveUp"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="?attr/doSkinButton"
            android:fontFamily="@font/poppins_bold"
            android:text="Como usted ordene!"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:cornerRadius="16dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
</FrameLayout>