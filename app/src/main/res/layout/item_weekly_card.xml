<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lunes 5 abril"
            android:textAlignment="center"
            android:fontFamily="@font/anton_regular"
            android:textSize="20sp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:id="@+id/layoutMissionGradient"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Misiones"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvMissionsCount"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:background="@drawable/bg_capsule_white"
                    android:text="10"
                    android:textColor="?attr/doSkinButton"
                    android:gravity="center"
                    android:fontFamily="@font/anton_regular"
                    android:textSize="24sp"
                    android:elevation="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutProjectGradient"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Proyectos"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvProjectsCount"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:background="@drawable/bg_capsule_white"
                    android:text="1"
                    android:textColor="?attr/doSkinButton"
                    android:gravity="center"
                    android:fontFamily="@font/anton_regular"
                    android:textSize="24sp"
                    android:elevation="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Lo más importante:"
            android:textColor="?attr/doSkinButton"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvImportant1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_bold"
            android:textSize="10sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="6dp"
            android:text="45 Xp   Misión 1" />

        <TextView
            android:id="@+id/tvImportant2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_bold"
            android:textSize="10sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="6dp"
            android:text="100 Xp   Misión 2" />

        <TextView
            android:id="@+id/tvImportant3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_bold"
            android:textSize="10sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="150 Xp   Misión 3" />

    </LinearLayout>
</androidx.cardview.widget.CardView>