<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <include
        android:id="@+id/header"
        layout="@layout/include_dashboard_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/btnAcceptPunishment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvStatsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analizando tu personalidad..."
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="?attr/doSkinSubtitle"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatsSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Para ser tu nuevo, necesito ver tus trapos sucios. Dame acceso a tu tiempo de uso de tu pantallita."
                android:textSize="13sp"
                android:gravity="center"
                android:textColor="#666"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="24dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#EAEAEA"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="?attr/doSkinButton"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnGrantPermission"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="¡Revisar mi celular!"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/white"
                        android:backgroundTint="?attr/doSkinButton"
                        app:cornerRadius="25dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardVices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/layoutStatsGradient"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="?attr/doSkinStart">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TUS PEORES VICIOS"
                        android:textColor="@color/white"
                        android:fontFamily="@font/anton_regular"
                        android:textSize="22sp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="16dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopVices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_top_vice" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvVerdict"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:gravity="center"
                android:textColor="?attr/doSkinSubtitle"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="Tu arquetipo actual es 'ZOMBIE DE PANTALLA'. Te voy a destruir esos vicios."/>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnAcceptPunishment"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Acepto!"
        android:textSize="18sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:backgroundTint="?attr/doSkinButton"
        app:cornerRadius="30dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="visible"/>

</androidx.constraintlayout.widget.ConstraintLayout>