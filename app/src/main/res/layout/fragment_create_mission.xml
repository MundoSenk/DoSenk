<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/createMissionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/bg_capsule_white"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        android:elevation="4dp"
        app:tint="?attr/doSkinButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:fontFamily="@font/anton_regular"
        android:text="Nueva Misión"
        android:textColor="@color/white"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/etMissionName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_dashed_border"
                        android:hint="¿Cómo se llama tu sufrimiento?"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textPersonName" />

                    <EditText
                        android:id="@+id/etMissionDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:background="@drawable/bg_dashed_border"
                        android:hint="Detalles de la misión (opcional)..."
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="12sp"
                        android:padding="16dp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:maxLines="4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_clock_outline"
                            app:tint="?attr/doSkinButton"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duración del castigo"
                            android:fontFamily="@font/anton_regular"
                            android:textColor="#333333"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4"
                        android:layout_marginBottom="12dp">

                        <TextView android:id="@+id/btn15m" android:layout_weight="1" android:layout_width="0dp" android:layout_marginEnd="4dp" android:text="15m" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btn30m" android:layout_weight="1" android:layout_width="0dp" android:layout_marginEnd="4dp" android:text="30m" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btn45m" android:layout_weight="1" android:layout_width="0dp" android:layout_marginEnd="4dp" android:text="45m" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btn60m" android:layout_weight="1" android:layout_width="0dp" android:text="1h" style="@style/MissionChipStyle"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCustomTime"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:text="Tiempo Personalizado"
                        android:background="@drawable/bg_dashed_border"
                        android:gravity="center"
                        android:textColor="#888888"
                        android:fontFamily="@font/poppins_semibold"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_calendar_star"
                            app:tint="?attr/doSkinButton"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¿Cuándo inicia?"
                            android:fontFamily="@font/anton_regular"
                            android:textColor="#333333"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/btnDatePicker"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="50dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dashed_border"
                            android:gravity="center"
                            android:text="Día único"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/btnTimePicker"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="50dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_dashed_border"
                            android:gravity="center"
                            android:text="Hora"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="#888888"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_sync"
                            app:tint="?attr/doSkinButton"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Repetición (Opcional)"
                            android:fontFamily="@font/anton_regular"
                            android:textColor="#333333"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="7"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:padding="4dp"
                        android:layout_marginBottom="8dp">

                        <TextView android:id="@+id/btnDay1" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="L" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btnDay2" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="M" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btnDay3" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="M" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btnDay4" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="J" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btnDay5" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="V" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btnDay6" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="S" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btnDay7" android:layout_weight="1" android:layout_width="0dp" android:layout_marginHorizontal="2dp" android:text="D" style="@style/MissionChipStyle"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Si seleccionas días, esto se convertirá en una rutina y el Día Único se ignorará."
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="#AAAAAA"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginBottom="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_magic_wand"
                            app:tint="?attr/doSkinButton"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Asignación"
                            android:fontFamily="@font/anton_regular"
                            android:textColor="#333333"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <TextView android:id="@+id/btnAuto" android:layout_weight="1" android:layout_width="0dp" android:text="En un hueco libre" android:textSize="11sp" android:layout_marginEnd="8dp" style="@style/MissionAssignmentStyle"/>
                        <TextView android:id="@+id/btnManual" android:layout_weight="1" android:layout_width="0dp" android:text="Horario Fijo" android:textSize="11sp" android:layout_marginStart="8dp" style="@style/MissionAssignmentStyle"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/btnNextToBlockZone"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="CONTINUAR AL BLOQUEO ->"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_bold"
        android:textSize="16sp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>