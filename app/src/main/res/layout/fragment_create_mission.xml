<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/createMissionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"> <ImageView
    android:id="@+id/btnBack"
    android:layout_width="48dp"
    android:layout_height="48dp"
    android:layout_marginTop="32dp"
    android:background="@drawable/bg_capsule_white"
    android:padding="12dp"
    android:src="@android:drawable/ic_menu_revert"
    android:elevation="4dp"
    app:tint="?attr/doSkinButton"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/anton_regular"
        android:text="Nueva Misión"
        android:textColor="@color/white"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFormContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="-32dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="48dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="24dp"
                android:paddingHorizontal="24dp">

                <EditText
                    android:id="@+id/etMissionName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_capsule_white"
                    android:hint="¿Cuál es el nombre del sufrimiento?"
                    android:fontFamily="@font/poppins_medium"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawablePadding="8dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="16dp"
                    android:inputType="textPersonName" />

                <EditText
                    android:id="@+id/etMissionDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:background="@drawable/bg_capsule_white"
                    android:hint="Que es lo que vas a realizar?.."
                    android:fontFamily="@font/poppins_medium"
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:gravity="top|start"
                    android:elevation="2dp"
                    android:layout_marginBottom="24dp"
                    android:inputType="textMultiLine"
                    android:maxLines="4" />



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿En cuánto tiempo lo resuelves?"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#3D3D5C"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">

                        <TextView android:id="@+id/btn15m" android:text="15 min" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btn30m" android:text="30 min" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btn45m" android:text="45 min" style="@style/MissionChipStyle"/>
                        <TextView android:id="@+id/btn60m" android:text="1 hr" style="@style/MissionChipStyle"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCustomTime"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:paddingHorizontal="32dp"
                        android:text="Personalizada"
                        android:background="@drawable/bg_capsule_white"
                        android:gravity="center"
                        android:textColor="#333333"
                        android:fontFamily="@font/poppins_semibold"
                        android:textSize="14sp"
                        android:elevation="2dp" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Cuándo inicia el castigo?"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#3D3D5C"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/btnDatePicker"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_capsule_white"
                        android:gravity="center"
                        android:text="Día"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="#888888"
                        android:drawableStart="@android:drawable/ic_menu_my_calendar"
                        android:paddingHorizontal="16dp"
                        android:elevation="2dp"/>

                    <TextView
                        android:id="@+id/btnTimePicker"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_capsule_white"
                        android:gravity="center"
                        android:text="Hora"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="#888888"
                        android:drawableStart="@android:drawable/ic_menu_recent_history"
                        android:paddingHorizontal="16dp"
                        android:elevation="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <TextView android:id="@+id/btnAuto" android:text=">Do en un hueco\nque tengas" style="@style/MissionAssignmentStyle"/>
                    <Space android:layout_width="12dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/btnManual" android:text="Manualmente" style="@style/MissionAssignmentStyle"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnNextToBlockZone"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:paddingHorizontal="32dp"
                    android:gravity="center"
                    android:text="¡A asignar el\nbloqueo!"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="16sp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>