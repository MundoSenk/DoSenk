<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_top_rounded_white"
    android:backgroundTint="#121212"
    android:orientation="vertical"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¡MISIÓN COMPLETADA!"
        android:textAlignment="center"
        android:fontFamily="@font/anton_regular"
        android:textColor="@color/white"
        android:textSize="28sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resultados, ¿de verdad lo conseguiste?"
        android:textAlignment="center"
        android:fontFamily="@font/poppins_bold"
        android:textColor="#00C853"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="24dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="XP Base por tiempo:" android:textColor="#AAAAAA" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tvBaseXp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+0 XP" android:textColor="@color/white" android:fontFamily="@font/poppins_bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Bono de Racha:" android:textColor="#AAAAAA" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tvStreakXp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+0 XP" android:textColor="#00C853" android:fontFamily="@font/poppins_bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Multiplicador:" android:textColor="#AAAAAA" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tvMultiplier" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="x1.0" android:textColor="#00C853" android:fontFamily="@font/poppins_bold"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#333333" android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TOTAL OBTENIDO:"
                android:textAlignment="center"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/poppins_bold"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tvTotalEarned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textAlignment="center"
                android:textColor="#00C853"
                android:fontFamily="@font/anton_regular"
                android:textSize="48sp"
                android:shadowColor="#4400C853"
                android:shadowDx="0" android:shadowDy="0" android:shadowRadius="20"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:layout_marginBottom="24dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/tvCurrentRank" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Rango Actual" android:textColor="@color/white" android:fontFamily="@font/poppins_bold"/>
            <TextView android:id="@+id/tvProgressText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / 1000 XP" android:textColor="#888888" android:fontFamily="@font/poppins_medium"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbLevelUp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_bar_custom" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="32dp">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/perro_tutorial"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tvSarcasticMessage"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Me sorprende que no hayas muerto de ansiedad. Úsalo sabiamente, aunque sé que no lo harás."
            android:textColor="#CCCCCC"
            android:fontFamily="@font/poppins_medium"
            android:textSize="11sp"
            android:textStyle="italic"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnClaimXp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="RECLAMAR XP Y VOLVER AL HOME"
        android:textColor="@color/white"
        android:background="@drawable/bg_capsule_white"
        android:backgroundTint="?attr/doSkinButton"
        android:fontFamily="@font/poppins_bold"
        android:textSize="14sp"
        android:elevation="8dp"/>

</LinearLayout>